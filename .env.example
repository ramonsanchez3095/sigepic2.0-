# Environment variables for SIGEPIC production deployment
# Copy this file to .env and configure values before starting

# PostgreSQL
POSTGRES_USER=sigepic
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=sigepic_db

# Backend
NODE_ENV=production
PORT=3000

# SECURITY CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# JWT Token Expiry
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Frontend API URL (build time)
VITE_API_URL=/api
