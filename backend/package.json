{
  "name": "sigepic-backend",
  "version": "2.0.0",
  "description": "Backend para Sistema de Gestión del Personal de Inteligencia Criminal",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:ts": "tsx watch src/server.js",
    "build": "tsc --build",
    "start": "node src/server.js",
    "start:ts": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js src/**/*.ts",
    "lint:fix": "eslint src/**/*.js src/**/*.ts --fix"
  },
  "keywords": [
    "policia",
    "gestion",
    "personal",
    "inteligencia"
  ],
  "author": "Departamento D-2",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0",
    "sharp": "^0.33.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1",
    "supertest": "^6.3.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
